# Azure ML Workspace
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_WORKSPACE_NAME=<your-workspace-name>

# Managed Identity (used by pipeline steps running on AML compute)
AZURE_MANAGED_IDENTITY_CLIENT_ID=<your-managed-identity-client-id>

# Compute & Environment (optional — defaults shown)
AZURE_COMPUTE_CLUSTER=gpu1
AZURE_ENVIRONMENT_NAME=brain-tumour-env@latest
